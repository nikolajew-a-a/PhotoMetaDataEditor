CREATE TABLE editLog (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    path TEXT NOT NULL,
    field TEXT NOT NULL,
    old_value TEXT,
    new_value TEXT NOT NULL,
    edited_at INTEGER NOT NULL
);

append:
INSERT INTO editLog(path, field, old_value, new_value, edited_at)
VALUES (:path, :field, :oldValue, :newValue, :editedAt);

selectByPath:
SELECT * FROM editLog WHERE path = :path ORDER BY edited_at DESC;
